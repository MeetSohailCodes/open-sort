{
  "name": "opensort",
  "version": "1.0.0",
  "description": "Avant-Garde Media Organization Tool",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "cross-env NODE_ENV=development concurrently \"npm run dev:frontend\" \"electron .\"",
    "dev:frontend": "cd frontend && npm run dev",
    "build:frontend": "cd frontend && npm run build",
    "build:backend": "cd backend && python -m PyInstaller --clean main.spec",
    "pack": "electron-builder --dir",
    "dist": "npm run build:frontend && npm run build:backend && electron-builder",
    "dist:win": "npm run build:frontend && npm run build:backend && electron-builder --win --x64 --arm64",
    "build:win": "node build-windows.js"
  },
  "build": {
    "appId": "com.meetsohail.opensort",
    "productName": "OpenSort",
    "icon": "build/icon",
    "electronLanguages": [
      "en-US"
    ],
    "compression": "maximum",
    "files": [
      "main.js",
      "preload.js",
      "assets/**/*",
      "frontend/dist/**/*"
    ],
    "extraResources": [
      {
        "from": "backend/dist/main.exe",
        "to": "backend_dist/main.exe"
      }
    ],
    "win": {
      "requestedExecutionLevel": "asInvoker",
      "target": [
        {
          "target": "nsis",
          "arch": ["x64", "arm64"]
        }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "OpenSort"
    }
  },
  "author": "Meet Sohail",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^40.0.0",
    "electron-builder": "^26.4.0",
    "wait-on": "^9.0.3"
  },
  "dependencies": {}
}
